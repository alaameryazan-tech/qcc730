  "${mbedtls_dir}/library/sha256.c",
  "${mbedtls_dir}/library/platform_util.c",
]

sbl_src = [
  "system/nt_bl_uart.c",
  "system/nt_bl_mem.c",
  "system/sbl_storage.c",
#  "system/sbl_flash_fwd.c",
  "system/rram_fdt.c",
  "system/nt_gpio.c",
  "system/qcspi_slave.c",
