  "${posix_fr_port_inc_dir}",
  "//build/freertos/common/config_files",
  "${mbedtls_dir}/include",
  "${mbedtls_dir}/include/mbedtls",
  "//include",
  "//lib/misc/inc",
  "//arch/arm/system/include/cmsis",
