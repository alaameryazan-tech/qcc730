]

if (CONFIG_MPU_ENABLE)
{
 # sbl_src += [ "${sbl_dir}/sbl_mpu/sbl_mpu.c", ]
}
source_set("HOSTED_SBL") {
    sources = pbl_dep_src
    sources += core_src
    sources += mbedtls_src
    sources += sbl_src
    if (CONFIG_BOARD_QCC730_QSPI_ENABLE) {
#        sources += [ "//modules/hal/qcc730/qspi/ferm_qspi.c" ]
#        sources += [ "//modules/hal/qcc730/flash/ferm_flash_config.c" ]
#        sources += [ "//modules/hal/qcc730/flash/ferm_flash.c" ]
    }
    include_dirs = inc_list
    defines = [
        "SBL_BUILD",
        "P_DEBUG",
        "CONFIG_NON_OS",
        "__LINUX_ERRNO_EXTENSIONS__",
    ]
    if (CONFIG_FLASH_XIP_SUPPORT) {
       defines += [
            "FLASH_XIP_SUPPORT",
       ]
   }
}
