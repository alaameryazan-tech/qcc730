  "../../comp/posix/include",
]

pbl_dep_src = [
#  "${sbl_dir}/elf_loader/boot_elf_loader.c",
#  "${sbl_dir}/elf_loader/boot_elf_mem.c",
  "${sbl_dir}/system/nt_bl_rram_dxe.c",
  "${sbl_dir}/debug/boot_print.c",
  "${sbl_dir}/debug/boot_log.c",
]

