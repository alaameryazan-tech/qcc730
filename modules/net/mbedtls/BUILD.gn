    "../../../../comp/mbedtls/library/x509_csr.c",
    "../../../../comp/mbedtls/library/x509write_crt.c",
    "../../../../comp/mbedtls/library/x509write_csr.c",
]

if (CONFIG_MBEDTLS_USE_PKA) {
    mbedtls_src += [
        "../../../../comp/mbedtls/port/bignum_alt.c",
        "../../../../comp/mbedtls/port/dhm_alt.c",
        "../../../../comp/mbedtls/port/ecdsa_alt.c",
        "../../../../comp/mbedtls/port/ecp_alt.c",
        "../../../../comp/mbedtls/port/ecp_curves_alt.c",
        "../../../../comp/mbedtls/port/rsa_alt.c",
    ]
}
else {
    mbedtls_src += [
        "../../../../comp/mbedtls/library/dhm.c",
        "../../../../comp/mbedtls/library/ecdsa.c",
        "../../../../comp/mbedtls/library/ecp.c",
        "../../../../comp/mbedtls/library/ecp_curves.c",
        "../../../../comp/mbedtls/library/rsa.c",
    ]
}

if(CONFIG_MBEDTLS_AES_ALT || CONFIG_MBEDTLS_CCM_ALT) {
    mbedtls_src += [
        "../../../../comp/mbedtls/port/aes_common.c",
        "../../../../comp/mbedtls/port/qccaes.c",
    ]
}

if(CONFIG_MBEDTLS_AES_ALT) {
    mbedtls_src += [
        "../../../../comp/mbedtls/port/aes_alt.c",
    ]
}

if(CONFIG_MBEDTLS_CCM_ALT) {
    mbedtls_src += [
        "../../../../comp/mbedtls/port/ccm_alt.c",
        "../../../../comp/mbedtls/port/aes_ccm.c",
    ]
}

if(CONFIG_MBEDTLS_SHA_ALT) {
    mbedtls_src += [
        "../../../../comp/mbedtls/port/sha_alt.c",
        "../../../../comp/mbedtls/port/qcc_digest.c",
    ]
}

if(CONFIG_HTTP_CLIENT) {
    mbedtls_src += [
        "../../../../comp/mbedtls/port/ssl_tls_alt.c",
    ]
}

config("_config") {
    include_dirs = mbedtls_inc
}

source_set("mbedtls") {
    sources = mbedtls_src
    cflags_c = [ "-w", ]
}
