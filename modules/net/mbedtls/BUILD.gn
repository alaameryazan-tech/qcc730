    "../../../../comp/mbedtls/library/ssl_ciphersuites.c",
    "../../../../comp/mbedtls/library/ssl_client.c",
    "../../../../comp/mbedtls/library/ssl_debug_helpers_generated.c",
    "../../../../comp/mbedtls/library/ssl_msg.c",
    "../../../../comp/mbedtls/library/ssl_tls12_client.c",
    "../../../../comp/mbedtls/library/ssl_tls13_client.c",
